generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============ USER & AUTH ============
model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  password      String
  phone         String?
  avatar        String?
  role          String   @default("admin") // super_admin, admin, editor, agent, viewer, seo_manager
  isActive      Boolean  @default(true)
  lastLogin     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  properties   Property[] @relation("AgentProperties")
  leads        Lead[]
  articles     Article[]
  activityLogs ActivityLog[]
  agentProfile AgentProfile?
}

// ============ PROPERTY TYPE ============
model PropertyType {
  id          String   @id @default(cuid())
  name        String   @unique // Rumah, Tanah, Ruko, Apartemen, Villa, Gudang, Kantor, Kost, Pabrik, Kavling, Komersial
  slug        String   @unique
  icon        String?
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  properties Property[]
}

// ============ LOCATION HIERARCHY ============
model Province {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cities     City[]
  properties Property[]
}

model City {
  id         String   @id @default(cuid())
  name       String
  slug       String
  provinceId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  province  Province  @relation(fields: [provinceId], references: [id])
  districts District[]
  properties Property[]
}

model District {
  id        String   @id @default(cuid())
  name      String
  slug      String
  cityId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  city     City     @relation(fields: [cityId], references: [id])
  villages Village[]
  properties Property[]
}

model Village {
  id         String   @id @default(cuid())
  name       String
  slug       String
  districtId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  district  District  @relation(fields: [districtId], references: [id])
  properties Property[]
}

// ============ PROPERTY ============
model Property {
  id              String   @id @default(cuid())
  code            String   @unique // auto-generated: PRP-YYYYMMDD-XXX
  title           String
  slug            String   @unique
  description     String   // long description HTML
  propertyTypeId  String
  status          String   @default("draft") // dijual, disewa, terjual, tersewa, draft
  isFeatured      Boolean  @default(false)
  isNego          Boolean  @default(false)
  isNew           Boolean  @default(false)
  isPublished     Boolean  @default(false)
  price           BigInt   @default(0)
  priceDisplay    String   // formatted price string

  // Location
  provinceId      String?
  cityId          String?
  districtId      String?
  villageId       String?
  address         String?
  latitude        Float?
  longitude       Float?

  // Specifications
  landArea        Int      @default(0)   // luas tanah m2
  buildingArea    Int      @default(0)   // luas bangunan m2
  bedrooms        Int      @default(0)
  bathrooms       Int      @default(0)
  garages         Int      @default(0)
  floors          Int      @default(0)
  electricity     String?  // daya listrik
  waterSource     String?  // sumber air
  certificate     String?  // SHM, SHGB, AJB, Girik
  buildingCond    String?  // baru, second, renovasi
  orientation     String?  // utara, selatan, timur, barat
  facilities      String?  // JSON array of facilities

  // Media
  mainImage       String?
  videoUrl        String?
  virtualTourUrl  String?

  // SEO
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?

  // Agent
  agentId         String?

  // Timestamps
  publishedAt     DateTime?
  deletedAt       DateTime? // soft delete
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  propertyType PropertyType @relation(fields: [propertyTypeId], references: [id])
  province      Province?  @relation(fields: [provinceId], references: [id])
  city          City?      @relation(fields: [cityId], references: [id])
  district      District?  @relation(fields: [districtId], references: [id])
  village       Village?   @relation(fields: [villageId], references: [id])
  agent         User?      @relation("AgentProperties", fields: [agentId], references: [id])
  images        PropertyImage[]
  leads         Lead[]

  @@index([slug])
  @@index([status])
  @@index([propertyTypeId])
  @@index([cityId])
  @@index([districtId])
  @@index([isFeatured])
  @@index([isPublished])
  @@index([price])
}

// ============ PROPERTY IMAGE ============
model PropertyImage {
  id         String   @id @default(cuid())
  propertyId String
  url        String
  altText    String?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

// ============ LEAD ============
model Lead {
  id              String   @id @default(cuid())
  name            String
  whatsapp        String
  email           String?
  phone           String?

  // Property interest
  propertyId      String?
  propertyName    String?  // denormalized for quick access
  locationInterest String?
  budget          String?
  propertyTypeInterest String?

  // Lead details
  needType        String   @default("beli") // beli, sewa, investasi, survei, tanya_harga
  source          String   @default("website") // website, google_ads, facebook_ads, instagram, whatsapp, artikel, referral
  status          String   @default("baru") // baru, dihubungi, prospek, survei, negosiasi, closing, gagal, spam
  notes           String?
  dpAmount        String?  // besaran DP dalam Rupiah
  promo           String?  // kode promo atau keterangan promo

  // Agent assignment
  agentId         String?

  // Follow-up
  nextFollowUp    DateTime?
  followUpNotes   String?  // JSON array of follow-up entries

  // Admin
  deletedAt       DateTime? // soft delete
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  property Property? @relation(fields: [propertyId], references: [id])
  agent    User?     @relation(fields: [agentId], references: [id])

  @@index([status])
  @@index([agentId])
  @@index([source])
  @@index([createdAt])
}

// ============ ARTICLE ============
model Article {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  content       String   // HTML content
  excerpt       String?
  categoryId    String?
  tags          String?  // JSON array of tags
  featuredImage String?
  isPublished   Boolean  @default(false)
  publishedAt   DateTime?
  scheduledAt   DateTime?

  // SEO
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?
  canonicalUrl    String?

  // Author
  authorId      String?

  // Stats
  viewCount     Int      @default(0)

  // Soft delete
  deletedAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  category ArticleCategory? @relation(fields: [categoryId], references: [id])
  author   User?            @relation(fields: [authorId], references: [id])

  @@index([slug])
  @@index([categoryId])
  @@index([isPublished])
  @@index([createdAt])
}

// ============ ARTICLE CATEGORY ============
model ArticleCategory {
  id        String     @id @default(cuid())
  name      String     @unique
  slug      String     @unique
  description String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  articles Article[]
}

// ============ AGENT (separate from User for frontend display) ============
model AgentProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  name      String
  title     String?  // jabatan
  photo     String?
  whatsapp  String
  email     String?
  bio       String?
  areaSpec  String?  // area spesialisasi
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([isActive])
}

// ============ WEBSITE SETTINGS (key-value) ============
model WebsiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
  group String @default("general") // general, social, seo, analytics, contact
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([group])
}

// ============ MEDIA ============
model Media {
  id        String   @id @default(cuid())
  filename  String
  url       String
  mimeType  String
  size      Int      @default(0)
  altText   String?
  folder    String   @default("/")
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([folder])
}

// ============ ACTIVITY LOG ============
model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String   // create, update, delete, login, logout, etc.
  entity    String?  // Property, Lead, Article, etc.
  entityId  String?
  details   String?  // JSON
  ipAddress String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}
